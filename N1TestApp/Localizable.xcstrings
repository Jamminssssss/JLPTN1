    "purchase.subscription_notice": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your subscription will renew automatically. You can cancel anytime before the renewal date."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La suscripción se renovará automáticamente. Puedes cancelarla en cualquier momento antes de la renovación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre abonnement se renouvelle automatiquement. Vous pouvez l'annuler à tout moment avant le renouvellement."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Langganan Anda akan diperpanjang secara otomatis. Anda dapat membatalkannya kapan saja sebelum tanggal perpanjangan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サブスクリプションは自動的に更新されます。更新日前であればいつでもキャンセルできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구독은 자동으로 갱신되며, 결제 전 언제든지 취소할 수 있습니다."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การสมัครสมาชิกของคุณจะต่ออายุโดยอัตโนมัติ คุณสามารถยกเลิกได้ทุกเมื่อก่อนวันต่ออายุ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gói đăng ký của bạn sẽ tự động gia hạn. Bạn có thể hủy bất cứ lúc nào trước ngày gia hạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的订阅将自动续订。您可以在续订日期前随时取消。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您的訂閱將自動續訂。您可以在續訂日期前隨時取消。"
          }
        }
      }
    },
